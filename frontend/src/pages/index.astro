---
import Layout from "../layouts/Layout.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout
  metaDescription="StephBe helps leaders and organisations gain clarity, build capability and create lasting performance through leadership development, workshops and coaching."
  metaKeywords="leadership development, organisational development, executive coaching, leadership coaching, strategy alignment, performance coaching"
  title="StephBe — Clarity for Leaders & Organisations"
  ogUrl="https://stephbe.ie/"
>
  <section class="hero-section">
    <div class="hero-content">
      <h1>
        Clarity for Leaders. <br />
        Creativity for Organisations. <br />
        Growth for Humans.
      </h1>
      <h4>
        I help leaders and forward-thinking organisations <br />
        cut through the noise, find their edge, and create lasting change.
      </h4>
      <div class="btn-section">
        <a href="/organisations" class="btn">For Organisations</a>
        <a href="/individual-performance" class="btn">For Individuals</a>
      </div>
    </div>
  </section>

  <section class="what-i-do">
    <div class="w-i-d">
      <h2>What I do</h2>
      <p>
        Sustainable performance is built at every level of an organisation. I partner with leaders and teams to align
        strategy, behaviour and capability — turning clarity into measurable impact.
      </p>
    </div>
    <div class="my-story">
      <div>
        <img
          src="./public/img/home/what-i-do.JPG"
          alt="What I do – leadership and organisational development at StephBe"
        />
      </div>
      <div>
        <h3 class="up-case">My Story</h3>
        <p>
          I work at the intersection of leadership, systems and performance — where complexity, pressure and people
          collide
        </p>
        <br />
        <p>
          I’m fascinated by what happens when clarity returns. When leaders stop reacting and start thinking
          strategically. When teams move from friction to alignment. When organisations operate with intent rather than
          urgency.
        </p>
        <br />
        <p>
          My work is grounded in a deep understanding of behaviour inside complex systems. Over time, I’ve focused my
          research and practice on helping organisations navigate people-related challenges with rigour and realism —
          aligning leadership behaviour with strategic ambition.
        </p>
        <br />
        <p>
          I don’t sit outside the system offering theory. I step inside it — naming what’s shaping performance and
          helping leaders shift it.
        </p>
        <a href="/my-story" class="btn-secondary"
          >Discover even more <img src="/icons/arrow_right.svg" alt="Arrow pointing right" /></a
        >
      </div>
    </div>
  </section>

  <section class="clarity-series">
    <div class="clarity-series-content">
      <span>Spotlight on</span>
      <h3>The Clarity Series Clarity as a Strategic Advantage</h3>
      <p>In complex, high-pressure environments, leaders don’t need more information — they need clarity.</p>
      <br />
      <p>
        The Clarity Series is a structured leadership framework designed to reduce organisational fog, strengthen trust
        and translate strategy into focused execution. Built on behavioural science and real-world leadership
        experience, this series helps organisations move from reactivity to alignment.
      </p>
      <ul>
        <li><img src="/icons/check.svg" alt="Checkmark" /> Clearer decision-making</li>
        <li><img src="/icons/check.svg" alt="Checkmark" /> Stronger leadership presence under pressure</li>
        <li><img src="/icons/check.svg" alt="Checkmark" /> Reduced friction across teams</li>
        <li><img src="/icons/check.svg" alt="Checkmark" /> Practical tools that stick</li>
        <li><img src="/icons/check.svg" alt="Checkmark" /> Performance that compounds</li>
      </ul>
      <p>
        Available as: • In-house workshops • Custom leadership series • Virtual delivery • Individual programmes Key
        note presentations
      </p>
      <div>
        <a
          class="btn-third"
          data-cal-link="stephbe/catch-up"
          data-cal-namespace="catch-up"
          data-cal-config='{"layout":"month_view"}'>Book a Clarity Conversation</a
        >
      </div>
    </div>
  </section>
</Layout>
